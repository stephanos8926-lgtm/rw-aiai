[Unit]
Description=vdrive-manager — mount virtual drives
Documentation=https://github.com/stephanos8926-lgtm/rw-aiai
DefaultDependencies=no
After=local-fs.target
Before=remote-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/vdrive-manager mount
ExecStop=/usr/local/bin/vdrive-manager umount
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=local-fs.target
